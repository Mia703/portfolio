---
interface Props {
	title: string;
	description: string;
	favicon: string;
}

const {
	title = "Amya Moore",
	description = "Amya's Personal Portfolio",
	favicon = "/favicon.svg",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="generator" content={Astro.generator} />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="author" content="Amya Moore" />
		<link rel="icon" type="image/svg+xml" href={ favicon } />
		<title>{title}</title>
	</head>
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-FV6JR9MP030"></script>
	<script>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());

		gtag('config', 'G-FV^JR9MP03');
	</script>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	/* =================== imported fonts =================== */
	@import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap");

	/* ---------- sub-header ---------- */

	/* =================== global variables =================== */
	:root {
		--main-colour-black: #1f1f21;
		--main-colour-white: #f4f4f4;
		--main-colour-grey: #808080;
		--main-cursor-colour: #d9d9d9;
		--main-accent-colour-yellow: #ffc600;
	}

	/* =================== reset default styles =================== */
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	/* =================== base page styles =================== */
	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: "Inter", sans-serif;
		font-size: 1em;
		font-weight: 400;
		color: var(--main-colour-white);
		background-color: var(--main-colour-black);
		padding: 1rem;
		position: relative;
	}

	/* =================== font styles =================== */
	h1 {
		font-size: 2.5em;
		color: var(--main-colour-grey);
		margin-bottom: 1rem;
	}

	h2 {
		font-size: 2em;
	}

	p {
		font-size: 1.2em;
		line-height: 1.5;
	}

	a {
		color: var(--main-colour-white);
		text-decoration: none;
	}

	/* underlines text */
	.em {
		border-bottom: solid 2px var(--main-colour-grey);
		transition: border 200ms ease-in-out;
	}

	.em:hover {
		border-color: var(--main-accent-colour-yellow);
	}

	button {
		width: 100%;
		font-weight: 400;
		font-size: 1em;
		padding: 0.5rem;
		border-radius: 5px;

		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		cursor: pointer;
	}

	button:hover {
		transform: translate(0, -0.3rem) scale(1);
		cursor: pointer;
	}

	footer p {
		font-size: 0.8em;
	}

	/* =================== constants =================== */
	/* exclude the following sections, but include for all other sections */
	section:not(.navigation-container, .header-section, .about-section) {
		margin-top: 6rem;
	}

	/* =================== media queries =================== */

	/* =================== TABLET =================== */
	@media only screen and (min-width: 40.063em) {
	
	}

	/* =================== DESKTOP =================== */
	@media only screen and (min-width: 64.063em) {
	
	}
</style>
